# --- Unity Temporary and Generated Folders (КРИТИЧНО) ---
# Ці папки містять гігабайти тимчасового локального кешу.
# Їх обов'язково треба ігнорувати, щоб репозиторій був чистим.
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Build]/
/[Builds]/
/[Logs]/
/[UserSettings]/
/[MemoryCaptures]/

# --- Unity specific assembly files ---
*.asmdef
*.meta

# --- Ігнорування матеріалів ---
# Повністю виключає всі файли матеріалів (.mat) з репозиторію GitHub
*.mat
